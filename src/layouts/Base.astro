---
import config from "@/config/config.json";
import { resolveContentImageUrl } from "@/lib/images";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { AstroFont } from "astro-font";
import { ClientRouter } from "astro:transitions";

// font families
const pf = theme.fonts.font_family.primary;

let fontPrimary;
if (theme.fonts.font_family.primary) {
  fontPrimary = theme.fonts.font_family.primary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;]+/gi, "");
}

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string | ImageMetadata;
  noindex?: boolean;
  canonical?: string;
  ogType?: "website" | "article";
  structuredData?: Record<string, any> | Array<Record<string, any>>;
}

// distructure frontmatters
const {
  title,
  meta_title,
  description,
  image,
  noindex,
  canonical,
  ogType = "website",
  structuredData,
} = Astro.props;
const siteUrl = new URL(config.site.base_url);
const pageUrl = canonical
  ? new URL(canonical, siteUrl).toString()
  : new URL(Astro.url.pathname, siteUrl).toString();
const pageTitle = plainify(
  meta_title ? meta_title : title ? title : config.site.title,
);
const pageDescription = plainify(
  description ? description : config.metadata.meta_description,
);
const resolvedMetaImage = resolveContentImageUrl(
  image ? image : config.metadata.meta_image,
);
const metaImageUrl = new URL(
  resolvedMetaImage || config.metadata.meta_image,
  siteUrl,
).toString();
const isHomePage = Astro.url.pathname === "/";
const schemaNodes = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: config.site.title,
    url: siteUrl.toString(),
    logo: new URL(config.site.logo, siteUrl).toString(),
    description: plainify(config.metadata.meta_description),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: pageTitle,
    url: pageUrl,
    description: pageDescription,
    inLanguage: "en-PK",
    isPartOf: {
      "@type": "WebSite",
      name: config.site.title,
      url: siteUrl.toString(),
    },
  },
  ...(isHomePage
    ? [
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          name: config.site.title,
          url: siteUrl.toString(),
          description: plainify(config.metadata.meta_description),
          inLanguage: "en-PK",
          potentialAction: {
            "@type": "SearchAction",
            target: `${siteUrl.toString()}search?q={search_term_string}`,
            "query-input": "required name=search_term_string",
          },
        },
      ]
    : []),
  ...(Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : []),
];
---

<!doctype html>
<html lang="en-PK">
  <head>
    <!-- google tag manager -->
    {
      config.google_tag_manager.enable && (
        <>
          <script is:inline>
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
          </script>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtm.js?id=${config.google_tag_manager.gtm_id}`}
          ></script>
        </>
      )
    }

    <!-- favicon -->
    <link rel="icon" type="image/svg+xml" href={config.site.favicon} />
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="compound-pk" />
    <meta name="application-name" content={config.site.title} />
    <meta name="msapplication-TileColor" content="#10243F" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#F8FAFC"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#10243F"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css -->
    <AstroFont
      config={[
        {
          src: [],
          preload: false,
          display: "swap",
          name: fontPrimary!,
          fallback: "sans-serif",
          cssVariable: "font-primary",
          googleFontsURL: `https://fonts.googleapis.com/css2?family=${pf}&display=swap`,
        },
      ]}
    />

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>{pageTitle}</title>

    <!-- canonical url -->
    <link rel="canonical" href={pageUrl} item-prop="url" />

    <!-- robots -->
    <meta
      name="robots"
      content={
        noindex
          ? "noindex,nofollow"
          : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
      }
    />

    <!-- meta-description -->
    <meta
      name="description"
      content={pageDescription}
    />

    <ClientRouter />

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />
    <meta property="og:site_name" content={config.site.title} />
    <meta property="og:locale" content="en_PK" />

    <!-- og-title -->
    <meta property="og:title" content={pageTitle} />

    <!-- og-description -->
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={pageUrl} />

    <!-- twitter-title -->
    <meta name="twitter:title" content={pageTitle} />

    <!-- twitter-description -->
    <meta name="twitter:description" content={pageDescription} />

    <!-- og-image -->
    <meta property="og:image" content={metaImageUrl} />

    <!-- twitter-image -->
    <meta name="twitter:image" content={metaImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaNodes)} />
  </head>
  <body>
    {/* google tag manager noscript */}
    {
      config.google_tag_manager.enable && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${config.google_tag_manager.gtm_id}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[70] focus:rounded-md focus:bg-dark focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
