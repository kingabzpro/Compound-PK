---
import {
  BiLineChart,
  BiSolidBank,
  BiSolidDollarCircle,
  BiSolidDroplet,
  BiSolidMedal,
} from "react-icons/bi";
import { fallbackSeed, getSeedMap } from "@/lib/marketPulse";

type MarketTile = {
  key: string;
  label: string;
  sourceUrl: string;
  accentClass: string;
  icon: typeof BiLineChart;
  value: string;
  change: string;
  asOf: string;
};

const defaultTiles: Omit<MarketTile, "value" | "change" | "asOf">[] = [
  {
    key: "kmi30",
    label: "KMI 30",
    sourceUrl: "https://dps.psx.com.pk/dataportal/",
    accentClass: "bg-primary/12 text-primary",
    icon: BiLineChart,
  },
  {
    key: "gold",
    label: "Gold",
    sourceUrl: "https://api.gold-api.com/price/XAU",
    accentClass: "bg-amber-100 text-amber-700",
    icon: BiSolidMedal,
  },
  {
    key: "silver",
    label: "Silver",
    sourceUrl: "https://api.gold-api.com/price/XAG",
    accentClass: "bg-slate-200 text-slate-700",
    icon: BiSolidMedal,
  },
  {
    key: "crude",
    label: "Brent",
    sourceUrl: "https://finance.yahoo.com/quote/BZ=F/",
    accentClass: "bg-rose-100 text-rose-700",
    icon: BiSolidDroplet,
  },
  {
    key: "kibor",
    label: "KIBOR 3M",
    sourceUrl: "https://www.sbp.org.pk/ecodata/FER/index.asp",
    accentClass: "bg-sky-100 text-sky-700",
    icon: BiSolidBank,
  },
  {
    key: "usdPkr",
    label: "USD/PKR",
    sourceUrl: "https://open.er-api.com/v6/latest/USD",
    accentClass: "bg-emerald-100 text-emerald-700",
    icon: BiSolidDollarCircle,
  },
];

const seedMap = await getSeedMap();
const marketTiles: MarketTile[] = defaultTiles.map((tile) => ({
  ...tile,
  value: seedMap[tile.key]?.value ?? fallbackSeed[tile.key]?.value ?? "Live",
  change: seedMap[tile.key]?.change ?? fallbackSeed[tile.key]?.change ?? "",
  asOf: seedMap[tile.key]?.asOf ?? fallbackSeed[tile.key]?.asOf ?? "Live",
}));
---

<aside
  class="market-pulse-panel relative overflow-hidden rounded-[1.3rem] border border-primary/10 bg-white/42 p-1.5 shadow-[0_12px_28px_rgba(13,118,110,0.08)] backdrop-blur-md"
  data-market-pulse
>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-12 bg-gradient-to-b from-primary/8 to-transparent" />
  <div class="relative mb-1 flex items-center justify-between gap-2">
    <p class="mb-0 text-[0.58rem] font-semibold uppercase tracking-[0.18em] text-primary/75">
      Market Pulse
    </p>
    <div class="inline-flex items-center gap-1 rounded-full border border-primary/15 bg-primary/8 px-1.5 py-0.5 text-[0.56rem] font-semibold text-primary">
      <span class="h-1.5 w-1.5 rounded-full bg-primary shadow-[0_0_0_3px_rgba(13,118,110,0.10)]" />
      Live
    </div>
  </div>

  <div class="relative grid grid-cols-2 gap-1">
    {
      marketTiles.map((tile) => {
        const Icon = tile.icon;

        return (
          <a
            href={tile.sourceUrl}
            target="_blank"
            rel="noreferrer"
            class="group rounded-[0.95rem] border border-white/45 bg-white/34 px-1.5 py-[0.5rem] transition duration-200 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-white/55"
            data-market-tile={tile.key}
            title={`${tile.label}: ${tile.value}. ${tile.change}. ${tile.asOf}.`}
          >
            <div class="flex items-center justify-between gap-2">
              <div class:list={["inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg", tile.accentClass]}>
                <Icon className="h-3.5 w-3.5" />
              </div>
              <p
                class="mb-0 text-[0.44rem] font-semibold uppercase tracking-[0.14em] text-text/40 transition group-hover:text-primary"
                data-market-as-of
              >
                {tile.asOf}
              </p>
            </div>
            <div class="mt-1.5 flex min-h-[3.7rem] flex-col justify-center text-left">
              <p
                class="mb-0 text-[0.56rem] font-semibold uppercase tracking-[0.12em] text-text/68"
                data-market-label
              >
                {tile.label}
              </p>
              <p
                class="mb-0 mt-0.5 text-[0.78rem] font-bold leading-tight text-dark"
                data-market-value
              >
                {tile.value}
              </p>
              <p class="mb-0 mt-0.5 text-[0.54rem] font-semibold leading-none text-primary/80" data-market-meta>
                {tile.change}
              </p>
            </div>
          </a>
        );
      })
    }
  </div>

  <p class="relative mb-0 mt-1 text-[0.46rem] leading-3 text-text/45">
    Sources: PSX, SBP, commodity feeds, and FX feeds.
  </p>
</aside>

<script>
  const pulsePanel = document.querySelector("[data-market-pulse]");

  if (pulsePanel) {
    type TileUpdate = {
      value?: string;
      change?: string;
      asOf?: string;
    };

    const REFRESH_INTERVAL_MS = 60_000;

    const setTile = (key: string, next: TileUpdate) => {
      const tile = pulsePanel.querySelector(`[data-market-tile="${key}"]`);
      if (!tile) return;

      const label = tile.querySelector("[data-market-label]");
      const value = tile.querySelector("[data-market-value]");
      const meta = tile.querySelector("[data-market-meta]");
      const asOf = tile.querySelector("[data-market-as-of]");

      if (value && next.value) value.textContent = next.value;
      if (meta && next.change) meta.textContent = next.change;
      if (asOf && next.asOf) asOf.textContent = next.asOf;

      const labelText = label?.textContent?.trim() ?? key;
      const valueText = value?.textContent?.trim() ?? "";
      const changeText = meta?.textContent?.trim() ?? "";
      const asOfText = asOf?.textContent?.trim() ?? "";

      tile.setAttribute("title", `${labelText}: ${valueText}. ${changeText}. ${asOfText}.`);
    };

    const fetchJson = async (url: string) => {
      const response = await fetch(url, { cache: "no-store" });
      if (!response.ok) {
        throw new Error(`Failed to fetch ${url}`);
      }
      return response.json();
    };

    let refreshInFlight = false;

    const refreshTiles = async () => {
      if (refreshInFlight) return;
      refreshInFlight = true;

      try {
        const payload = await fetchJson("/api/market-pulse");

        Object.entries(payload as Record<string, TileUpdate>).forEach(([key, update]) => {
          setTile(key, update);
        });
      } catch (error) {
        console.error("Market pulse refresh failed", error);
      } finally {
        refreshInFlight = false;
      }
    };

    void refreshTiles();
    window.setInterval(() => {
      if (document.visibilityState === "hidden") return;
      void refreshTiles();
    }, REFRESH_INTERVAL_MS);

    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        void refreshTiles();
      }
    });
  }
</script>
