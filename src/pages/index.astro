---
import Posts from "@/components/Posts.astro";
import config from "@/config/config.json";
import DynamicIcon from "@/helpers/DynamicIcon";
import Base from "@/layouts/Base.astro";
import MarketPulse from "@/layouts/components/MarketPulse.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);
const startPaths = [
  {
    id: "mindset",
    title: "Build the Right Investing Mindset",
    description:
      "Start with long-term habits before products. Avoid short-term noise and costly mistakes.",
    url: "/categories/mindset",
    cta: "Explore Mindset",
    panelClass: "border-primary/10 bg-gradient-to-br from-primary/10 via-white to-primary/5",
    inkClass: "text-primary/70",
    iconBgClass: "bg-primary/12 text-primary",
    icons: ["FaSeedling", "FaChartLine", "FaBullseye"],
  },
  {
    id: "pakistan",
    title: "Start Investing in Pakistan",
    description:
      "Learn the first practical actions, account setup flow, and decision framework for beginners.",
    url: "/categories/pakistan-investing",
    cta: "Start Pakistan Investing",
    panelClass: "border-amber-200/60 bg-gradient-to-br from-amber-100/80 via-white to-amber-50/40",
    inkClass: "text-amber-700/75",
    iconBgClass: "bg-amber-100 text-amber-700",
    icons: ["FaCoins", "FaBuildingColumns", "FaArrowTrendUp"],
  },
  {
    id: "global",
    title: "Add Global Diversification",
    description:
      "Understand global market exposure and how to layer international assets into a FIRE plan.",
    url: "/categories/global-investing",
    cta: "Explore Global Investing",
    panelClass: "border-sky-200/60 bg-gradient-to-br from-sky-100/80 via-white to-sky-50/40",
    inkClass: "text-sky-700/70",
    iconBgClass: "bg-sky-100 text-sky-700",
    icons: ["FaGlobe", "FaLayerGroup", "FaChartPie"],
  },
];
---

<Base
  title="Compound PK"
  description="Long-term investing, simplified. Practical investing strategies for Pakistanis pursuing financial independence."
>
  <section class="section pb-8 pt-10">
    <div class="container">
      <div class="relative overflow-hidden rounded-3xl border border-border bg-light px-6 py-10 md:px-12 md:py-14 lg:min-h-[25.5rem]">
        <div class="pointer-events-none absolute -right-24 -top-24 h-56 w-56 rounded-full bg-primary opacity-10" />
        <div class="pointer-events-none absolute -left-16 -bottom-16 h-44 w-44 rounded-full bg-dark opacity-5" />

        <div class="relative lg:max-w-[calc(100%-17rem)] lg:pr-8">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">
            Long-term investing, simplified.
          </p>
          <h1 class="h2 mb-4 max-w-3xl">Build Wealth. Retire Early. Stay Free.</h1>
          <p class="mb-8 max-w-2xl text-lg text-text">
            Practical investing strategies for Pakistanis pursuing financial
            independence.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/categories/mindset" class="btn btn-primary">Start Here</a>
            <a href="/categories" class="btn btn-outline-primary">
              Browse Categories
            </a>
          </div>
        </div>

        <div class="relative mt-8 lg:absolute lg:right-6 lg:top-1/2 lg:mt-0 lg:w-[15.5rem] lg:-translate-y-1/2">
          <MarketPulse />
        </div>
      </div>
    </div>
  </section>

  <section class="section pb-8 pt-4">
    <div class="container">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-primary">
            Start With A Path
          </p>
          <h2 class="h3">Choose your next investing step</h2>
        </div>
        <a href="/categories" class="text-sm font-semibold text-primary hover:text-dark">
          View all categories
        </a>
      </div>
      <div class="row gy-4">
        {
          startPaths.map((path) => (
            <div class="col-12 md:col-6 lg:col-4">
              <article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-white p-6 transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_70px_rgba(15,52,96,0.08)]">
                <div class={`relative mb-5 overflow-hidden rounded-[1.35rem] border px-4 py-3 ${path.panelClass}`}>
                  <div class={`pointer-events-none flex min-h-[4.5rem] items-center justify-between gap-3 ${path.inkClass}`}>
                    <div class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl ${path.iconBgClass}`}>
                      <DynamicIcon icon={path.icons[0]} className="block h-5.5 w-5.5" />
                    </div>
                    <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
                      <div class="h-px min-w-4 flex-1 bg-current opacity-15" />
                      <div class="flex h-6 w-6 shrink-0 items-center justify-center opacity-28">
                        <DynamicIcon icon="FaArrowRightLong" className="block h-3 w-3" />
                      </div>
                      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/80 shadow-[0_8px_24px_rgba(255,255,255,0.6)]">
                        <div class="flex h-5 w-5 items-center justify-center">
                          <DynamicIcon icon={path.icons[1]} className="block h-4.5 w-4.5" />
                        </div>
                      </div>
                      <div class="h-px w-4 shrink-0 bg-current opacity-15" />
                      <div class="flex h-6 w-6 shrink-0 items-center justify-center opacity-28">
                        <DynamicIcon icon="FaArrowRightLong" className="block h-3 w-3" />
                      </div>
                      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/80 shadow-[0_8px_24px_rgba(255,255,255,0.6)]">
                        <div class="flex h-5 w-5 items-center justify-center">
                          <DynamicIcon icon={path.icons[2]} className="block h-4.5 w-4.5" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <h3 class="relative h5 mb-3 max-w-[14ch]">{path.title}</h3>
                <p class="relative mb-6 max-w-[30ch] text-text">{path.description}</p>
                <a href={path.url} class="relative mt-auto font-semibold text-primary hover:text-dark">
                  {path.cta}
                </a>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="latest-articles" class="section pt-8">
    <div class="container">
      <div class="mb-10 flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-primary">
            Latest Articles
          </p>
          <h2 class="h3">Recent posts for long-term investors</h2>
        </div>
        <a href="/search" class="text-sm font-semibold text-primary hover:text-dark">
          Search all posts
        </a>
      </div>
      <Posts posts={currentPosts} className="mb-16" />
      <Pagination currentPage={1} totalPages={totalPages} />
    </div>
  </section>
</Base>
